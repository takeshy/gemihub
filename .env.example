GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PICKER_API_KEY=
GOOGLE_REDIRECT_URI=http://localhost:8132/auth/google/callback
SESSION_SECRET=
# Preferred: private Cloud Storage bucket read with application credentials.
GEMIHUB_OKF_BUCKET=
GEMIHUB_OKF_PREFIX=
# Self-hosted fallback: public HTTPS prefix containing the same objects.
GEMIHUB_OKF_BASE_URL=
HUBWORK_ADMIN_CREDENTIALS=user:password
# Hubwork (premium multi-tenant) features need Google Cloud credentials for
# Firestore. They auto-enable only when credentials exist: on Cloud Run, or
# via GOOGLE_APPLICATION_CREDENTIALS, or a gcloud ADC file
# (`gcloud auth application-default login`). Without credentials they are
# disabled and hubwork domains 404 — config-only vars like
# FIRESTORE_DATABASE_ID / GOOGLE_CLOUD_PROJECT do NOT enable them.
#FIRESTORE_DATABASE_ID=

#!/bin/sh
# Run typecheck + lint + build before allowing a commit. Matches `npm run precommit`.
# Build is included because React Router's server/client code-splitting produces
# errors (e.g. ".server module referenced by client") that only surface during
# the vite bundle pass, not during tsc.
# Enable once per clone:  git config core.hooksPath .githooks
set -e
cd "$(git rev-parse --show-toplevel)"
npm run typecheck
npm run lint
npm run build
